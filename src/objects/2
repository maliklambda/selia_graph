use std::{fs::OpenOptions, io::{Read, Seek, SeekFrom, Write}, os::unix::fs::FileExt};


use crate::{base_types::ID, constants::{self, lengths::{BYTE_LENGTH, BobjLen}, limits::MAX_BOBJ_SIZE}, types::type_management::TypeRef};


pub type PropertyId = ID;

struct Property {
    json_str: Option<String>,
    json_val: Option<serde_json::Value>,
}

impl Property {
    pub fn from_str (s: &str) -> Result<Property, String> {
        let v: serde_json::Value = serde_json::from_str(s)
            .map_err(|err| format!("Invalid json_string: {err}"))?;
        Ok(Property { json_str: Some(s.to_string()), json_val: Some(v) })
    }

    pub fn parse_str_unchecked (&mut self) {
        assert!(self.json_str.is_some());
        let v: serde_json::Value = serde_json::from_str(
            &self.json_str.clone().unwrap()
        ).unwrap();
        self.json_val = Some(v);
    }
}



#[derive(Debug)]
pub struct PropertyFile {
    pub file: std::fs::File,
    pub start_properties: usize,
}

impl PropertyFile {
    pub fn new (file_path: &std::path::Path) -> Result<Self, std::io::Error> {
        let file = OpenOptions::new()
            .read(true)
            .write(true)
            .open(file_path)?;
        Ok(Self {
            file,
            start_properties: constants::lengths::START_PROPERTIES,
        })
    }

    pub fn add_property (&mut self, property_str: &str, node_type: TypeRef) -> Result <PropertyId, String> {
        if node_type.constraints.is_none() { panic!("You silly goose, node_type.constraints cannot be None for this one."); }

        // Parse json String => return Error if invalid
        let v: serde_json::Value = serde_json::from_str(property_str)
            .map_err(|_| "Invalid JSON")?;

        // Check if all constraints are kept 
        // => e.g. Type has required field "start" => json_obj must include "start" at top_level
        if !assert_value_matches_type_reqs(v, node_type) {
            todo!("Handle invalid JSON string");
        }

        // str to Binary Object
        let b_json = property_str.as_bytes();
        if b_json.len() > MAX_BOBJ_SIZE as usize {
            todo!("Handle too long BOBJ length");
        }
        let b_len = b_json.len() as BobjLen;

        let mut buffer = b_len.to_ne_bytes().to_vec();
        buffer.extend_from_slice(b_json);

        // write buffer
        self.file.seek(SeekFrom::End(0))?;
        let new_prop_id = self.file.stream_position()? as u32;
        self.file.write_all(&buffer)?;

        Ok(new_prop_id)
    }

    pub fn read_property (&mut self, prop_id: PropertyId) -> Result<Property, std::io::Error> {
        // read size of Bobj
        let mut buf = [0_u8; (BobjLen::BITS/(BYTE_LENGTH as u32)) as usize];
        self.file.read_exact_at(&mut buf, prop_id as u64)?;
        let size = BobjLen::from_ne_bytes(buf);

        // read Bobj
        let mut buf = vec![0_u8; size as usize];
        self.file.read_exact(&mut buf)?;
        let json_val = Some(serde_json::from_slice::<serde_json::Value>(&buf)?);

        Ok(Property { json_str: None, json_val })
    }
}

fn assert_value_matches_type_reqs(val: serde_json::Value, node_type: TypeRef) -> bool {
    assert!(node_type.constraints.is_some());
    if let Some(json_val) = val.as_object() {
        let constraints = node_type.constraints.unwrap();
        // required_fields
        for rf in constraints.required_fields {
            if !json_val.contains_key(&rf) { return false }
        }
        true
    } 
    else { false }
}






